# IceBridge Relay Server Configuration
# Copy to .env and adjust as needed.
# All variables can also be set as environment variables (env vars take precedence).

# Bind address. Use 0.0.0.0 for all interfaces (required for cloud/EC2).
ICEBRIDGE_HOST=0.0.0.0

# rUDP mesh port (UDP). This is the port peers connect to for relayed search.
ICEBRIDGE_RUDP_PORT=6889

# Identity handshake port (TCP). Peers authenticate via TCP on this port.
# Default: 6888. Change if running alongside a desktop FrostWire instance.
ICEBRIDGE_RELAY_PORT=6888

# HTTP control API port (TCP). Bound to 127.0.0.1 only (never public).
# Aligns with icebridge-run-local.sh / EC2 install scripts (default 8081).
ICEBRIDGE_CONTROL_HTTP_PORT=8081

# Role: FORWARDER, CLIENT, or BOTH.
# Cloud/EC2 servers should use FORWARDER.
# Desktop/Android apps use BOTH.
ICEBRIDGE_ROLE=FORWARDER

# Path to the Ed25519 identity file. Created on first run if it doesn't exist.
# PoW mining (20 bits) takes ~2-5 seconds on first run.
ICEBRIDGE_IDENTITY_FILE=identity.dat

# Maximum number of tracked peers in the registry.
ICEBRIDGE_MAX_PEERS=10000

# Peer eviction TTL in seconds. Peers not heard from in this time are removed.
ICEBRIDGE_PEER_TTL_SEC=300

# Rate limit: max registrations per public key per second.
ICEBRIDGE_MAX_QPS_PER_KEY=30.0

# Announce on the frostwire-bootstrap-v1 DHT topic so new peers can find this relay.
# Should be true for public cloud forwarders.
ICEBRIDGE_BOOTSTRAP=true

# Embed minimal jlibtorrent SessionManager and announce on frostwire-relays-v1.
# Default true for FORWARDER/BOTH when loaded via fromEnv(); false for in-process builders.
ICEBRIDGE_DHT=true

# Multi-token control auth file (one hex token per line). Prefer this over a single token.
# ICEBRIDGE_AUTH_TOKENS_FILE=icebridge-tokens.txt

# --- Topology (hybrid EC2 hubs + FrostWire leaves) ---
# Production: high-speed EC2 IceBridge mesh we operate (not residential ultrapeers).
# Defaults from TopologyAutoResearch on hybrid EC2 benchmark (hit-rate vs traffic).
# LimeWire ultrapeer comparison: N=32 M=30 meshTTL=3 searchTTL=3 softMax=3
#
# N: mesh RELAY fanout among IceBridge hubs (EC2 fleet is small + fat; N=8 covers)
ICEBRIDGE_MESH_FANOUT=8
# M: FrostWire peers queried per hop at a hub (rare-content recall)
ICEBRIDGE_SEARCH_PEER_FANOUT=30
# Mesh RELAY hop TTL
ICEBRIDGE_MESH_HOP_TTL=3
# Dual-envelope search TTL
ICEBRIDGE_SEARCH_TTL=3
# Soft max: hops+remaining_ttl clamp
ICEBRIDGE_SOFT_MAX=3
# Leaf clients attach to this many IceBridges (prefer EC2 hubs)
ICEBRIDGE_LEAF_UP_CONNECTIONS=3
